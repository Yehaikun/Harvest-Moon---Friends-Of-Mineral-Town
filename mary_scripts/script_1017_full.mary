    const MESSAGE_24 = "Hi, \xFF!!\r\nI hear you've been doing\r\nmighty well at the farm!\x05"
    const MESSAGE_25 = "People like me depend on\r\npeople like you to grow our\r\nfood, \x05\r\nso you have my gratitude!\x05"
