    const MESSAGE_16 = "I bet that's not going\r\nto happen though, is it?\x05"
    const MESSAGE_17 = "Hmmm...Looks like it's not\r\ngoing to stop. \x05\x0CAnd I was going to go to \r\nthe Square, too!\x05"
