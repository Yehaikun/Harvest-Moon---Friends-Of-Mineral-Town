    const MESSAGE_9 = "How wonderful!\r\nThis is really for me?!...\x05"
    const MESSAGE_10 = "How wonderful!\x05\x0CYou really know how to win\r\na girl's heart, \r\n\xFF!.\x05\x0CI bet all the girls are \r\nchasing you, aren't they?\x05"
    const MESSAGE_11 = "How beautiful!\r\nI can't believe this is \r\nreally for me.\x05"
    const MESSAGE_12 = "You want to learn how to\r\nmake some fabulous \r\nChocolate Cookies? Jeff\x05\r\njust loves this recipe.\x05\x0CThe ingredients are Flour,\r\nButter, Eggs, and Chocolate.\x05\x0CYou also need Sugar of \r\ncourse and Honey is optional\x05\x0CThe only implements you \r\nneed are a Rolling Pin and\r\nOven. \x05\x0CYou can also get by with\r\njust Chocolate and Cookies,\r\ntoo.Karen likes liquor, but\x05\r\nnot sweets, you know.\x05"
    const MESSAGE_13 = "This really brings back\r\nmemories...Jeff gave me \r\nthe same thing, once. \x05\x0CI still have it, you know.\x05"
    const MESSAGE_14 = "Welcome, \xFF!.\x05\x0CHow is life with Karen?\x05"
    const MESSAGE_15 = "How is \xFF*?\r\nHe looks so much like\r\nhis mother...\x05\x0CI can't wait to see \r\nhim again!\x05"
    const MESSAGE_16 = "How are you?\x05"
    const MESSAGE_17 = "If you need my help about\r\nanything, don't be\r\nafraid to ask.\x05"
    const MESSAGE_18 = "Jeff says his stomach hurts\r\nwhen it rains or snows.\r\nCan you believe that?\x05"
