    const MESSAGE_28 = "Hi, \xFF!. \r\nImagine meeting you here!\x05"
    const MESSAGE_29 = "I hear things are tough for \r\nBarley and May over at \r\nYodel Farm. It's just \r\nthe two of them. \x05\x0CGo over for a visit\r\nif you have the time. \x05"
