    const MESSAGE_0 = "I don't think I've seen you\r\naround here before. \x05\x0COh, you're at the farm, \r\nare you? Welcome to the \r\nboonies.\x05\x0CThe name's Gray. \x05"
    const MESSAGE_1 = "Wow! What a surprise!\x05\x0CWhat's a classy guy like you\r\ndoing in a place like this?\x05"
    const MESSAGE_2 = "Thanks! I like having\r\nclassy friends like you.\x05"
