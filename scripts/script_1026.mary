    const MESSAGE_17 = "How is Mary doing?\x05"
    const MESSAGE_18 = "Tell her hi for me. \x05"
    const MESSAGE_19 = "I hate it around here.\r\nThere's nothing to do.\r\nDon't you think so too?\x05"
    const MESSAGE_20 = "I just get so bored in this \r\ntown. I want to go back to\r\nthe city!\x05"
    const MESSAGE_21 = "Hey, \xFF!, what \r\ndo you think of the girl\r\nwho works in the Library?\x05"
    const MESSAGE_22 = "I go to the Library a lot\r\nthese days. I like reading\r\nbooks all the sudden.\x05"
    const MESSAGE_23 = "I had no idea books were\r\nso much fun!\x05"
    const MESSAGE_24 = "Did you know Mary writes \r\nnovels! That's amazing. \x05\x0CI hope one day I can craft\r\nsomething, too.\x05"
    const MESSAGE_25 = "Working hard, I see. \x05"
    const MESSAGE_26 = "Lately I've been getting \r\nalong better with gramps. \x05\x0CI'm enjoying working as a \r\nblacksmith more and more.\x05"
    const MESSAGE_27 = "Mary's different from the \r\nother girls. \x05\x0CI want her to like me!\x05"
    const MESSAGE_28 = "All I can do is try my best\r\nto learn the blacksmith \r\ntrade, and read lots of \x05\r\nbooks. \x05\x0CHopefully, she'll notice!\x05"
    const MESSAGE_29 = "I hear neat stories from\r\nMary's father alll the time. \x05"
    const MESSAGE_30 = "I like books, too, but\r\nI'm never to give up \r\non being a blacksmith.\x05"
    const MESSAGE_31 = "My grampa is so hard on \r\nme for every little thing!\r\nI can hardly stand it!\x05"
    const MESSAGE_32 = "I wonder how old my \r\ngrandfather is...\x05\x0CHow can he still be so \r\nstrong!?...\x05"
