    const MESSAGE_11 = "Ahh...What a beautiful smell!\x05"
    const MESSAGE_12 = "Want to learn how to \r\nmake ice cream?\x05\x0CMay makes me make it for\r\nher all the time.\x05\x0CAll you need is Sugar, \r\nMilk, and Eggs, and of \r\nof course a Whisk and \x05\r\na Pot.\x05\x0CMay loves it when I slice \r\nup Pineapple and Apple with\r\nmy knife and add it in \x05\r\nwith Honey. Myself, I like \r\nit with Wild Grapes. You \r\nshould give it a try.\x05"
