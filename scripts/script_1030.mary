    const MESSAGE_22 = "Dogs really are smart, \r\nyou know. The more you play\r\ncatch with a dog, the \x05\r\nbetter it'll get. \x05"
    const MESSAGE_23 = "Did you remember to \r\nPut your Cows and Chickens \r\nin the Barn?\x05"
    const MESSAGE_24 = "You'll catch cold if\r\nyou're not careful!\x05"
    const MESSAGE_25 = "Did you come to play?\x05"
    const MESSAGE_26 = "Come any time you want, now!\x05"
    const MESSAGE_27 = "Is the farm working out\r\nwell for you? It must be \r\nquite a job to restore that\x05\r\nplace, but good luck!\x05"
