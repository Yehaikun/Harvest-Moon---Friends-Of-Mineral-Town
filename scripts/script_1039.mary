{
    const MESSAGE_0 = "Racers in the F-3.14 MGP\r\nare as follows:\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81ESylvia\r\n\x81@On Futaba\r\n\x81@Using Spirit Magic\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nHer magic is well-balanced\r\nbetween offense and defense,\r\nand she always races well.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81EMiltonia\r\n\x81@On Sprite\r\n\x81@Using White Magic\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nShe uses restorative magic,\r\nso she prefers to race\r\npretty hard, and then heal\r\nherself afterwards.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nThat's all for today. The\r\nfirst match will be the day\r\nafter tomorrow.\x05"
    const MESSAGE_1 = "Racers in the F-3.14 MGP\r\nare as follows:\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81ELeatrice\r\n\x81@On Sana\r\n\x81@Using Voodoo\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nShe can always be seen\r\ngoing around before the race\r\nwith dolls and needles. She\r\ndoesn't do much at all\r\nduring the race proper.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81ELavender\r\n\x81@On Starlight\r\n\x81@Using Divination\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nShe always divines who will\r\nwin before a race starts.\r\nRumor has it her predictions\r\nare 100% accurate.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nThat's all for today. The\r\nfirst match will be\r\ntomorrow.\x05"
    const MESSAGE_2 = "The results of the first\r\nF-3.14 MGP Race are:\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nFrom the start, the race was\r\nbetween Sylvia and Lupinus.\r\nSylvia's Wind Magic gave her\r\nan early lead over Lupinus,\r\nbut Lupinus stuck to Sylvia\r\nlike glue for the rest of\r\nthe race!\r\nIn the final lap, Lupinus\r\ncast an illusionary turn on\r\nSylvia, who was 0.2 seconds\r\nahead, but Sylvia's Earth\r\nMagic blocked it easily, and\r\nshe held on to her lead and\r\nwon the race.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nFor now, we have the top\r\nthree racers. We'll post the\r\nfull results tomorrow.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nRace Results:\r\n1st Place: Sylvia\r\n2nd Place: Lupinus\r\n3rd Place: Miltonia\x05"
    const MESSAGE_3 = "The results of the first\r\nF-3.14 MGP Race are:\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nYesterday's Race Results:\r\n1st Place: Sylvia   +10\r\n2nd Place: Lupinus   +6\r\n3rd Place: Miltonia\x81@+4\r\n4th Place: Daisy   +3\r\n5th Place: Cosmos   +2\r\n6th Place: Amaryllis   +1\r\n7th Place: Moraea\r\n8th Place: Leatrice\r\n9th Place: Lavender\r\n10th Place: Lilac\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nPoint Standings:\r\n1st Place: Sylvia   10\r\n2nd Place: Lupinus   6 \r\n3rd Place: Miltonia\x81@4 \r\n4th Place: Daisy    3 \r\n5th Place: Cosmos   2 \r\n6th Place: Amaryllis   1\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nAnd there you have it.\x05"
    const MESSAGE_4 = "Racers in the F-3.14 MGP\r\nare as follows:\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81EDaisy\r\n\x81@On Peony\r\n\x81@Using Light Magic\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nCan anyone catch her when\r\nshe uses her Shining Wing\r\nspell?\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81ECosmos\r\n\x81@On Peony\r\n\x81@Using Darkness Magic\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nCosmos, Daisy's twin sister,\r\nhas magic opposite but\r\nalmost as powerful in her\r\nDark Wing spell, which ought\r\nto be interesting.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nThat's all for today. The\r\nsecond match will be the day\r\nafter tomorrow.\x05"
    const MESSAGE_5 = "Racers in the F-3.14 MGP\r\nare as follows:\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81EAmaryllis\r\n\x81@On Sakuya\r\n\x81@Using Flower Magic\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nAll her magic does is create\r\nflowers, which really isn't\r\nthat useful in racing...\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81ELiliac\r\n\x81@On Karin\r\n\x81@Trainee in Magic\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nAs a trainee, Lilac has no\r\nmagic yet. Let's hope she\r\neventually makes good.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nThat's all for today. The\r\nsecond match will be\r\ntomorrow.\x05"
    const MESSAGE_6 = "The results of the second\r\nF-3.14 MGP Race are:\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nSylvia continues to perform\r\nvery well, while Lupinus had\r\ntrouble with her machine and\r\ncouldn't use much magic,\r\ngiving her a hard time. The\r\nLight-Dark Sisters, Daisy\r\nand Cosmos, nearly gained on\r\nSylvia with their Light and\r\nDark Wing spells, but\r\ncouldn't quite make it, and\r\nSylvia stayed in the lead to\r\nwin her second consecutive\r\nrace.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nFor now, we have the top\r\nthree racers. We'll post the\r\nfull results tomorrow.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nRace Results:\r\n1st Place: Sylvia\r\n2nd Place: Daisy\r\n3rd Place: Cosmos\x05"
    const MESSAGE_7 = "The results of the second\r\nF-3.14 MGP Race are:\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nYesterday's Race Results:\r\n1st Place: Sylvia   +10 \r\n2nd Place: Daisy   +6\r\n3rd Place: Cosmos   +4\r\n4th Place: Miltonia   +3\r\n5th Place: Lupinus   +2\r\n6th Place: Amaryllis   +1\r\n7th Place: Moraea\r\n8th Place: Lavender\r\n9th Place: Leatrice\r\n10th Place: Lilac\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nPoint Standings:\r\n1st (unch.): Sylvia  20\r\n2nd (up): Daisy  9\r\n3rd (up): Lupinus  8\r\n4th (down): Miltonia  7\r\n5th (unch.): Cosmos  6\r\n6th (unch.): Amaryllis  2\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nAnd there you have it.\x05"
    const MESSAGE_8 = "Racers in the F-3.14 MGP\r\nare as follows:\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81EMoraea\r\n\x81@On Natsuki\r\n\x81@Using Summoning Magic\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nI've never seen her summon\r\nanything, though, so I don't\r\nrightly know just what this\r\nmeans.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81ELupinus\r\n\x81@On Misuzu\r\n\x81@Using Illusion Magic\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nAll she does is illusion, so\r\nif you figure that out,\r\nshe's totally powerless.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nThat's all for today. The\r\nthird match will be the day\r\nafter tomorrow.\x05"
    const MESSAGE_9 = "Racers in the F-3.14 MGP\r\nare as follows:\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81ESylvia\r\n\x81@On Futaba\r\n\x81@Using Spirit Magic\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nHer magic is well-balanced\r\nbetween offense and defense,\r\nand she always races well.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\x81|\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81EMiltonia\r\n\x81@On Sprite\r\n\x81@Using White Magic\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nShe uses restorative magic,\r\nso she prefers to race\r\npretty hard, and then heal\r\nherself afterwards.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nThat's all for today. The\r\nthird match will be\r\ntomorrow.\x05"
    const MESSAGE_10 = "The results of the third\r\nF-3.14 MGP Race are:\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nSylvia hit Leatrice, who was\r\nlagging behind, taking them\r\nboth out of the race! That\r\nled to Lupinus taking the\r\nlead, and comfortably\r\nwinning the race.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nMiltonia, Daisy, and Cosmos\r\nfought it out for 2nd Place,\r\nwith Miltonia using her\r\nrestorative magic in the\r\nfinal lap, easily holding on\r\nto 2nd Place.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nFor now, we have the top\r\nthree racers. We'll post the\r\nfull results tomorrow.\r\n\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\x81@\r\nRace Results:\r\n1st Place: Lupinus\r\n2nd Place: Miltonia\r\n3rd Place: Cosmos\x05"
