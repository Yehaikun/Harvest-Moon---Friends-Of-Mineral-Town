    const MESSAGE_8 = "If your Chickens become\r\nsick, you can heal them with\r\nAnimal Medicine. \x05\x0CThis may be purchased at\r\nthe Poultry Farm or Yodel\r\nFarm. \x05"
    const MESSAGE_9 = "You can heal sick Chickens \r\nby using Animal Medicine\r\nnext to them. \x05"
