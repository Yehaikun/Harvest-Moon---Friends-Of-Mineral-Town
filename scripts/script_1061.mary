    const MESSAGE_0 = "You must give your Chickens \r\nChicken Feed everyday. \x05\x0CTake the Feed from the \r\nFeed Bin and put it in the \r\nFeed Boxes. \x05"
    const MESSAGE_1 = "Put one bushel of Feed \r\nin the Feed Box for every\r\nChicken you have. \x05\x0CIf you don't give them\r\nenough, your Chickens will\r\nbecome unhappy. \x05"
    const MESSAGE_2 = "To raise healthy animals, \r\nit's necessary to spend \r\nlots of time with them. \x05"
    const MESSAGE_3 = "Press the A Button close \r\nto your Chickens to lift \r\nthem up.\x05"
    const MESSAGE_4 = "Press the A Button again to\r\nset the Chicken back down. \r\nThis is how you increase \x05\r\naffection of your Chickens.\x05"
    const MESSAGE_5 = "Next, ship the Eggs laid\r\nby your Chickens. \x05"
    const MESSAGE_6 = "Press the A Button next to\r\nan Egg to pick it up. \x05"
